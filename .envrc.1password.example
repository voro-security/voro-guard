# Alternative local-only secrets for voro-guard using 1Password CLI.
#
# Usage:
#   cp .envrc.1password.example .envrc
#   edit the op:// references for your vault/item names
#   direnv allow

export CODE_INDEX_SERVICE_TOKEN="$(op read 'op://Dev/voro-guard/service-token')"
export CODE_INDEX_SIGNING_KEY="$(op read 'op://Dev/voro-guard/signing-key')"

# Optional: only needed when indexing private GitHub repositories.
# export CODE_INDEX_GITHUB_TOKEN="$(op read 'op://Dev/github-voro/index-read-pat')"
