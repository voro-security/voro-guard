# FastAPI service runtime
CODE_INDEX_TRUST_MODE=strict
CODE_INDEX_SIGNER=voro-index-guard
CODE_INDEX_SIGNING_KEY=change-me-signing-key
ARTIFACT_ROOT=./data/artifacts
CODE_INDEX_SERVICE_TOKEN=change-me-service-token
CODE_INDEX_GITHUB_TOKEN=
CODE_INDEX_MAX_FILES=400
CODE_INDEX_MAX_FILE_SIZE_BYTES=512000
CODE_INDEX_MAX_SYMBOLS_PER_FILE=200
CODE_INDEX_INDEX_TIMEOUT_SECONDS=30
CODE_INDEX_POLLER_ENABLED=0
CODE_INDEX_POLLER_CONFIG=./config/poll.json

# Adaptive learning backplane
VORO_ADAPTIVE_LEARNING=0

# MCP / managed-server client mode
INDEX_GUARD_URL=http://127.0.0.1:18765
# Defaults to CODE_INDEX_SERVICE_TOKEN when unset.
INDEX_GUARD_TOKEN=
INDEX_GUARD_MANAGED_PORT=18765
INDEX_GUARD_STARTUP_TIMEOUT=15
